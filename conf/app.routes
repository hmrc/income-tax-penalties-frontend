# microservice specific routes

->         /hmrc-frontend             hmrcfrontend.Routes
GET        /                          uk.gov.hmrc.incometaxpenaltiesfrontend.controllers.AdminController.index(sort: Seq[String], filter: Seq[String], page: Option[Int])
GET        /check-file-url/:reference uk.gov.hmrc.incometaxpenaltiesfrontend.controllers.AdminController.checkFileUrl(reference: String)
GET        /submission/:reference     uk.gov.hmrc.incometaxpenaltiesfrontend.controllers.AdminController.submission(reference: String)
GET        /assets/*file              controllers.Assets.versioned(path = "/public", file: Asset)
